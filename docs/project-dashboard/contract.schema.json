{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nadaa.local/schemas/project-dashboard-record.json",
  "title": "NADAA Project Dashboard Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client",
    "project",
    "phase",
    "sprint",
    "epic",
    "story",
    "jiraKey",
    "branchName",
    "pullRequestUrl",
    "status",
    "assignedTeamMember",
    "estimatedEffortPoints",
    "actualEffortHours",
    "progressPercentage",
    "lastUpdated",
    "dependencies",
    "blockers",
    "verification"
  ],
  "properties": {
    "client": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": ["MVP", "Phase 2", "Phase 3"]
    },
    "sprint": {
      "type": "string",
      "minLength": 1
    },
    "epic": {
      "type": "string",
      "minLength": 1
    },
    "story": {
      "type": "string",
      "minLength": 1
    },
    "jiraKey": {
      "type": "string",
      "pattern": "^NADAA-[0-9]{3}$"
    },
    "branchName": {
      "type": "string"
    },
    "pullRequestUrl": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["Todo", "In Progress", "Blocked", "Review", "Done"]
    },
    "assignedTeamMember": {
      "type": "string"
    },
    "estimatedEffortPoints": {
      "type": "number",
      "minimum": 0
    },
    "actualEffortHours": {
      "type": "number",
      "minimum": 0
    },
    "progressPercentage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "lastUpdated": {
      "type": "string",
      "format": "date"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}

