# Public staging web URLs.
STAGING_CITIZEN_URL=https://citizen.staging.nadaa.example
STAGING_AUTHORITY_URL=https://authority.staging.nadaa.example
STAGING_DISPATCHER_URL=https://dispatcher.staging.nadaa.example

# Optional staging service base URLs. When set, `pnpm smoke:staging` checks `/healthz`.
STAGING_ALERT_SERVICE_URL=https://alert.staging.nadaa.example
STAGING_AUTH_SERVICE_URL=https://auth.staging.nadaa.example
STAGING_INCIDENT_SERVICE_URL=https://incident.staging.nadaa.example
STAGING_GUIDE_SERVICE_URL=https://guide.staging.nadaa.example
STAGING_INTEGRATION_SERVICE_URL=https://integration.staging.nadaa.example
STAGING_NOTIFICATION_SERVICE_URL=https://notification.staging.nadaa.example
STAGING_RISK_SERVICE_URL=https://risk.staging.nadaa.example

# Runtime configuration groups. Real values must live in the staging environment or secret manager.
DATABASE_URL=postgres://nadaa:<password>@<host>:5432/nadaa?sslmode=require
REDIS_URL=rediss://:<password>@<host>:6379/0
OBJECT_STORAGE_ENDPOINT=https://objects.staging.nadaa.example
OBJECT_STORAGE_BUCKET=nadaa-staging-media
OBJECT_STORAGE_ACCESS_KEY=<secret-manager-ref>
OBJECT_STORAGE_SECRET_KEY=<secret-manager-ref>
JWT_SECRET=<secret-manager-ref>
MFA_ISSUER=NADAA Staging
SMS_PROVIDER=sandbox
SMS_API_KEY=<secret-manager-ref>
WHATSAPP_PROVIDER=sandbox
WHATSAPP_API_KEY=<secret-manager-ref>
PUSH_PROVIDER=sandbox
PUSH_API_KEY=<secret-manager-ref>
NADAA_SMS_ENABLED=true
NADAA_PUSH_ENABLED=true
NADAA_NOTIFICATION_ADDR=:8090
NADAA_ALERT_SERVICE_URL=https://alert.staging.nadaa.example/api/v1
EMAIL_PROVIDER=sandbox
EMAIL_API_KEY=<secret-manager-ref>
ML_SERVICE_URL=https://ml.staging.nadaa.example
